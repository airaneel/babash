# babash MCP server configuration

# Docker Hub token for `make push`
# DOCKERHUB_TOKEN=dckr_pat_...

# Enable debug logging (shows all console.log output)
# BABASH_DEBUG=1

# Custom instructions injected into Initialize tool response
# BABASH_SERVER_INSTRUCTIONS="Always use python3 instead of python"

# Shell to use (defaults to $SHELL or /bin/bash)
# BABASH_SHELL=/bin/zsh

# Transport: stdio or streamable-http
BABASH_TRANSPORT=streamable-http

# Host and port for streamable-http transport
BABASH_HOST=0.0.0.0
BABASH_PORT=8000
